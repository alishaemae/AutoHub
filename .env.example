# Скопируйте этот файл в .env (рядом с docker-compose.yml) и заполните значения.
# Файл .env содержит секреты и не коммитится в репозиторий.

# Публичный адрес кабинета (поддомен)
PUBLIC_URL=https://lk.avto-hub.online

# Учётная запись администратора (вход в панель менеджера)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Пароль базы данных PostgreSQL (задайте надёжный)
DB_PASSWORD=

# Секретный ключ приложения.
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Почтовый ящик для писем клиентам (SMTP)
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Ключ сервиса электронной подписи Podpislon
PODPISLON_API_KEY=
